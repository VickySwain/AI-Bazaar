# ═══════════════════════════════════════════════════════════════════════════
# CoverAI — Master Environment Configuration
# Copy this to .env in each service directory and edit as needed.
# ═══════════════════════════════════════════════════════════════════════════

# ─── SHARED INFRASTRUCTURE ─────────────────────────────────────────────────
# These are the same across all services when running in Docker Compose.

# PostgreSQL
DATABASE_HOST=localhost              # Docker: postgres
DATABASE_PORT=5432
DATABASE_USER=coverai
DATABASE_PASSWORD=coverai_secret
DATABASE_NAME=coverai_db

# Redis (NestJS uses DB 0, ML service uses DB 1)
REDIS_HOST=localhost                 # Docker: redis
REDIS_PORT=6379

# Kafka
KAFKA_BROKERS=localhost:9092         # Docker: kafka:29092

# ─── NEXT.JS FRONTEND (.env.local) ─────────────────────────────────────────
# File: coverai-frontend/.env.local

NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CoverAI

# ─── NESTJS BACKEND (.env) ─────────────────────────────────────────────────
# File: coverai-backend/.env

NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
FRONTEND_URL=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=coverai
DB_PASSWORD=coverai_secret
DB_NAME=coverai_db
DB_SYNCHRONIZE=true
DB_LOGGING=false

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TTL=300

JWT_SECRET=dev-jwt-secret-change-in-production-min-32-chars-abc123xyz
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-min-32-chars
JWT_REFRESH_EXPIRY=7d

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=coverai-backend
KAFKA_GROUP_ID=coverai-group

SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
EMAIL_FROM=noreply@coverai.in

TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ML service connection
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_TIMEOUT=5000
ML_MAX_RETRIES=2

THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── FASTAPI ML SERVICE (.env) ─────────────────────────────────────────────
# File: coverai-ml/.env

DEBUG=false
LOG_LEVEL=INFO
PORT=8000
WORKERS=4
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]

DATABASE_URL=postgresql://coverai:coverai_secret@localhost:5432/coverai_db

REDIS_URL=redis://localhost:6379/1
RECOMMENDATION_CACHE_TTL=3600
FEATURE_CACHE_TTL=1800

KAFKA_BROKERS=localhost:9092
KAFKA_GROUP_ID=coverai-ml-group

MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=coverai-recommendations

MODEL_VERSION=v1.0.0
MIN_SCORE_THRESHOLD=0.05
MIN_INTERACTIONS_FOR_RETRAIN=1000
RETRAIN_SCHEDULE_HOURS=24

# ─── PRODUCTION OVERRIDES ───────────────────────────────────────────────────
# When deploying, override these values via your cloud provider's secret manager
# (AWS Secrets Manager, GCP Secret Manager, Azure Key Vault, Doppler, etc.)

# JWT_SECRET=<random 64-char string from: openssl rand -hex 32>
# JWT_REFRESH_SECRET=<different random 64-char string>
# DATABASE_PASSWORD=<strong password>
# RAZORPAY_KEY_ID=rzp_live_xxxxx      (live key in production)
# RAZORPAY_KEY_SECRET=<live secret>
# SMTP_PASS=<real SendGrid API key>
